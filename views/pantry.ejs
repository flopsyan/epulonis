<%- include('partials/header') %>

<% const canEdit = locals.authed; %>

<div class="page-head">
  <h1><%= t('pantry_title') %></h1>
  <p class="page-sub"><%= t('pantry_sub') %></p>
</div>

<div class="pantry-layout <%= canEdit ? '' : 'readonly' %>">
  <% if (canEdit) { %>
  <section class="form-card pantry-form-card">
    <h2 class="form-section-title" id="pantry-form-title"><%= t('add_item') %></h2>
    <form class="pantry-form" method="post" action="/pantry" id="pantry-form">
      <div class="field">
        <label for="p-name"><%= t('p_item') %></label>
        <input type="text" id="p-name" name="name" required placeholder="<%= t('p_item_ph') %>" />
        <p class="hint"><%= t('p_item_hint') %></p>
      </div>
      <div class="grid-2">
        <div class="field">
          <label for="p-amount"><%= t('p_amount') %></label>
          <input type="text" id="p-amount" name="amount" inputmode="decimal" placeholder="<%= t('p_amount_ph') %>" />
        </div>
        <div class="field">
          <label for="p-unit"><%= t('p_unit') %></label>
          <input type="text" id="p-unit" name="unit" list="unit-list" placeholder="g / ml / pcs" />
        </div>
      </div>
      <div class="form-actions form-actions-inline">
        <button type="button" class="btn btn-ghost" id="pantry-reset" hidden><%= t('p_new') %></button>
        <button type="submit" class="btn btn-primary" id="pantry-submit"><%= t('save') %></button>
      </div>
    </form>
  </section>
  <% } %>

  <section class="pantry-list-wrap">
    <% if (items.length === 0) { %>
      <div class="empty-state small">
        <div class="empty-emoji">🧺</div>
        <h2><%= t('pantry_empty') %></h2>
        <p><%= t('pantry_empty_text') %></p>
      </div>
    <% } else { %>
      <div class="pantry-count"><%= items.length %> <%= items.length === 1 ? t('entry_one') : t('entry_many') %></div>
      <ul class="pantry-list">
        <% items.forEach((item) => { %>
          <li class="pantry-item"
              data-name="<%= item.name %>"
              data-amount="<%= item.amount === null ? '' : item.amount %>"
              data-unit="<%= item.unit %>">
            <span class="pantry-item-name"><%= item.name %></span>
            <span class="pantry-item-qty">
              <% if (item.amount !== null) { %><%= formatAmount(item.amount) %> <% } %><%= item.unit %>
            </span>
            <% if (canEdit) { %>
            <span class="pantry-item-actions">
              <button type="button" class="icon-btn pantry-edit" title="<%= t('p_edit') %>">✎</button>
              <form method="post" action="/pantry/<%= item.id %>/delete"
                    onsubmit="return confirm('<%= t('confirm_remove_1') %><%= item.name %><%= t('confirm_remove_2') %>');">
                <button type="submit" class="icon-btn danger" title="<%= t('p_remove') %>">🗑</button>
              </form>
            </span>
            <% } %>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>
</div>

<datalist id="unit-list">
  <option value="g"></option><option value="kg"></option>
  <option value="ml"></option><option value="l"></option>
  <option value="pcs"></option><option value="packet"></option>
  <option value="cloves"></option><option value="can"></option>
</datalist>

<%- include('partials/footer', { pageScript: 'pantry.js' }) %>
