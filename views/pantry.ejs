<%- include('partials/header') %>

<div class="page-head">
  <h1>Pantry</h1>
  <p class="page-sub">Add what you have at home – recipes then show live whether an ingredient is in stock.</p>
</div>

<div class="pantry-layout">
  <section class="form-card pantry-form-card">
    <h2 class="form-section-title" id="pantry-form-title">Add an item</h2>
    <form class="pantry-form" method="post" action="/pantry" id="pantry-form">
      <div class="field">
        <label for="p-name">Item</label>
        <input type="text" id="p-name" name="name" required placeholder="e.g. Flour" />
        <p class="hint">Same name as in the recipe ingredients = automatic match.</p>
      </div>
      <div class="grid-2">
        <div class="field">
          <label for="p-amount">Amount</label>
          <input type="text" id="p-amount" name="amount" inputmode="decimal" placeholder="e.g. 500" />
        </div>
        <div class="field">
          <label for="p-unit">Unit</label>
          <input type="text" id="p-unit" name="unit" list="unit-list" placeholder="g / ml / pcs" />
        </div>
      </div>
      <div class="form-actions form-actions-inline">
        <button type="button" class="btn btn-ghost" id="pantry-reset" hidden>New</button>
        <button type="submit" class="btn btn-primary" id="pantry-submit">Save</button>
      </div>
    </form>
  </section>

  <section class="pantry-list-wrap">
    <% if (items.length === 0) { %>
      <div class="empty-state small">
        <div class="empty-emoji">🧺</div>
        <h2>Pantry is empty</h2>
        <p>Add your first item on the left.</p>
      </div>
    <% } else { %>
      <div class="pantry-count"><%= items.length %> <%= items.length === 1 ? 'entry' : 'entries' %></div>
      <ul class="pantry-list">
        <% items.forEach((item) => { %>
          <li class="pantry-item"
              data-name="<%= item.name %>"
              data-amount="<%= item.amount === null ? '' : item.amount %>"
              data-unit="<%= item.unit %>">
            <span class="pantry-item-name"><%= item.name %></span>
            <span class="pantry-item-qty">
              <% if (item.amount !== null) { %><%= formatAmount(item.amount) %> <% } %><%= item.unit %>
            </span>
            <span class="pantry-item-actions">
              <button type="button" class="icon-btn pantry-edit" title="Edit">✎</button>
              <form method="post" action="/pantry/<%= item.id %>/delete"
                    onsubmit="return confirm('Remove „<%= item.name %>“ from the pantry?');">
                <button type="submit" class="icon-btn danger" title="Remove">🗑</button>
              </form>
            </span>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>
</div>

<datalist id="unit-list">
  <option value="g"></option><option value="kg"></option>
  <option value="ml"></option><option value="l"></option>
  <option value="pcs"></option><option value="packet"></option>
  <option value="cloves"></option><option value="can"></option>
</datalist>

<%- include('partials/footer', { pageScript: 'pantry.js' }) %>
