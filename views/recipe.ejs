<%- include('partials/header') %>

<%
  // Initial render of the pantry pill (JS recomputes live).
  function pill(status) {
    switch (status) {
      case 'ok':
      case 'available': return { cls: 'ok', icon: '✓', label: t('legend_ok') };
      case 'low':       return { cls: 'low', icon: '≈', label: t('legend_low') };
      case 'unknown':   return { cls: 'unknown', icon: '•', label: t('legend_ok') };
      default:          return { cls: 'missing', icon: '✕', label: t('legend_missing') };
    }
  }
  const totalTime = (recipe.prep_time || 0) + (recipe.cook_time || 0);
%>

<p class="breadcrumb"><a href="/"><%= t('back_all') %></a></p>

<article class="recipe" data-base-servings="<%= recipe.servings %>">
  <div class="recipe-hero">
    <span class="card-fallback" aria-hidden="true"><%= recipe.title.trim().charAt(0).toUpperCase() %></span>
    <% if (recipe.image_url) { %>
      <img src="<%= recipe.image_url %>" alt="<%= recipe.title %>" onerror="this.remove()" />
    <% } %>
  </div>

  <header class="recipe-head">
    <% if (recipe.tags && recipe.tags.length) { %>
      <div class="chips">
        <% recipe.tags.forEach((tag) => { %>
          <a class="chip" href="/?tag=<%= tag.slug %>"><%= tag.name %></a>
        <% }) %>
      </div>
    <% } %>

    <h1><%= recipe.title %></h1>
    <% if (recipe.description) { %><p class="lead"><%= recipe.description %></p><% } %>

    <div class="badges">
      <% if (formatTime(recipe.prep_time)) { %>
        <div class="badge"><span class="badge-ico">⏱</span><span><span class="badge-k"><%= t('prep') %></span><span class="badge-v"><%= formatTime(recipe.prep_time) %></span></span></div>
      <% } %>
      <% if (formatTime(recipe.cook_time)) { %>
        <div class="badge"><span class="badge-ico">🔥</span><span><span class="badge-k"><%= t('cook') %></span><span class="badge-v"><%= formatTime(recipe.cook_time) %></span></span></div>
      <% } %>
      <% if (formatTime(totalTime)) { %>
        <div class="badge"><span class="badge-ico">⏲</span><span><span class="badge-k"><%= t('total') %></span><span class="badge-v"><%= formatTime(totalTime) %></span></span></div>
      <% } %>
      <div class="badge"><span class="badge-ico">📊</span><span><span class="badge-k"><%= t('difficulty') %></span><span class="badge-v"><%= t('diff_' + recipe.difficulty) %></span></span></div>
    </div>

    <div class="recipe-actions">
      <a class="btn btn-ghost" href="/recipe/<%= recipe.slug %>/edit">✎ <%= t('edit') %></a>
      <form method="post" action="/recipe/<%= recipe.slug %>/delete" onsubmit="return confirm('<%= t('confirm_delete') %>');">
        <button type="submit" class="btn btn-danger">🗑 <%= t('delete') %></button>
      </form>
    </div>
  </header>

  <div class="recipe-layout">
    <aside class="ingredients card">
      <div class="ing-head">
        <h2><%= t('ingredients') %></h2>
        <div class="servings-stepper" role="group" aria-label="<%= t('adjust_servings') %>">
          <button type="button" class="step-btn" data-step="-1" aria-label="<%= t('fewer') %>">−</button>
          <label class="servings-field">
            <input type="number" id="servings-input" min="1" step="1"
                   value="<%= recipe.servings %>" aria-label="<%= t('servings_label') %>" />
            <span class="servings-unit" id="servings-unit"><%= recipe.servings_unit %></span>
          </label>
          <button type="button" class="step-btn" data-step="1" aria-label="<%= t('more') %>">+</button>
        </div>
      </div>

      <p class="pantry-hint">
        <%= t('pantry_hint_1') %> <a href="/pantry"><%= t('pantry_link') %></a>.
      </p>

      <ul class="ingredient-list">
        <% recipe.ingredients.forEach((ing) => { %>
          <% const p = pill(ing.status); %>
          <li class="ingredient"
              data-name="<%= ing.name %>"
              data-base-amount="<%= ing.amount === null ? '' : ing.amount %>"
              data-unit="<%= ing.unit %>">
            <span class="ing-amount">
              <span class="amount"><%= ing.amount === null ? '' : formatAmount(ing.amount) %></span>
              <span class="unit"><%= ing.unit %></span>
            </span>
            <span class="ing-name">
              <%= ing.name %><% if (ing.note) { %><span class="ing-note"><%= ing.note %></span><% } %>
            </span>
            <span class="pantry-pill <%= p.cls %>"><span class="pill-ico"><%= p.icon %></span><span class="pill-label"><%= p.label %></span></span>
          </li>
        <% }) %>
      </ul>

      <div class="pantry-legend">
        <span><i class="dot ok"></i> <%= t('legend_ok') %></span>
        <span><i class="dot low"></i> <%= t('legend_low') %></span>
        <span><i class="dot missing"></i> <%= t('legend_missing') %></span>
      </div>
    </aside>

    <section class="method">
      <% if (recipe.notes) { %>
        <div class="notes-box">
          <span class="notes-ico">📌</span>
          <div>
            <strong><%= t('note') %></strong>
            <p><%= recipe.notes %></p>
          </div>
        </div>
      <% } %>

      <h2><%= t('instructions') %></h2>
      <% if (recipe.steps.length) { %>
        <ol class="step-list">
          <% recipe.steps.forEach((s) => { %>
            <li><span class="step-text"><%= s.text %></span></li>
          <% }) %>
        </ol>
      <% } else { %>
        <p class="muted"><%= t('no_instructions') %></p>
      <% } %>
    </section>
  </div>
</article>

<script type="application/json" id="pantry-data"><%- pantryJson %></script>

<%- include('partials/footer', { pageScript: 'recipe.js' }) %>
