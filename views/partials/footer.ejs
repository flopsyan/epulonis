  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <span><strong><%= siteName %></strong> · your self-hosted recipe collection</span>

      <div class="footer-right">
        <span class="footer-links">
          <a href="/">All recipes</a>
          <a href="/pantry">Pantry</a>
          <a href="/new">Add recipe</a>
        </span>
        <div class="theme-switch" role="group" aria-label="Color theme">
          <button type="button" class="theme-btn" data-theme-choice="system">System</button>
          <button type="button" class="theme-btn" data-theme-choice="light">Light</button>
          <button type="button" class="theme-btn" data-theme-choice="dark">Dark</button>
        </div>
      </div>
    </div>
  </footer>

  <script type="module" src="/static/js/theme.js"></script>
  <script type="module" src="/static/js/search.js"></script>
  <% if (typeof pageScript !== 'undefined' && pageScript) { %>
    <script type="module" src="/static/js/<%= pageScript %>"></script>
  <% } %>
</body>
</html>
