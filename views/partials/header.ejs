<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= (typeof title !== 'undefined' && title) ? title + ' · ' + siteName : siteName %></title>
  <meta name="description" content="Selbstgehostete Rezeptplattform – Rezepte sammeln, suchen, Portionen skalieren und mit dem eigenen Vorrat abgleichen." />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%23c8543b'/%3E%3Ctext x='50' y='52' font-size='62' font-family='Georgia,serif' fill='white' text-anchor='middle' dominant-baseline='central'%3EE%3C/text%3E%3C/svg%3E" />
  <link rel="stylesheet" href="/static/css/styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="/">
        <span class="brand-name"><%= siteName %></span>
      </a>

      <form class="search" action="/" method="get" role="search" autocomplete="off">
        <span class="search-icon" aria-hidden="true">🔍</span>
        <input
          type="search"
          name="q"
          id="search-input"
          placeholder="Rezepte durchsuchen …"
          value="<%= searchQuery %>"
          aria-label="Rezepte durchsuchen"
        />
        <div class="search-results" id="search-results" role="listbox" hidden></div>
      </form>

      <nav class="nav">
        <a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>">Rezepte</a>
        <a href="/vorrat" class="nav-link <%= currentPath.startsWith('/vorrat') ? 'active' : '' %>">Vorrat</a>
        <a href="/neu" class="btn btn-primary nav-new">+ Neues&nbsp;Rezept</a>
      </nav>
    </div>
  </header>

  <main class="container main">
