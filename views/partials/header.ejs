<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= (typeof title !== 'undefined' && title) ? title + ' · ' + siteName : siteName %></title>
  <meta name="description" content="Self-hosted recipe platform – collect, search and scale recipes and match ingredients against your own pantry." />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%23c8543b'/%3E%3Ctext x='50' y='52' font-size='62' font-family='Georgia,serif' fill='white' text-anchor='middle' dominant-baseline='central'%3EE%3C/text%3E%3C/svg%3E" />
  <script>
    // Apply the saved theme before paint to avoid a flash of the wrong theme.
    (function () {
      try {
        var t = localStorage.getItem('epulonis-theme');
        if (t === 'dark' || t === 'light') document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    })();
  </script>
  <link rel="stylesheet" href="/static/css/styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="/">
        <span class="brand-name"><%= siteName %></span>
      </a>

      <form class="search" action="/" method="get" role="search" autocomplete="off">
        <span class="search-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </span>
        <input
          type="search"
          name="q"
          id="search-input"
          placeholder="Search recipes …"
          value="<%= searchQuery %>"
          aria-label="Search recipes"
        />
        <div class="search-results" id="search-results" role="listbox" hidden></div>
      </form>

      <nav class="nav">
        <a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>">Recipes</a>
        <a href="/pantry" class="nav-link <%= currentPath.startsWith('/pantry') ? 'active' : '' %>">Pantry</a>
        <a href="/new" class="btn btn-primary nav-new">+ New&nbsp;recipe</a>
      </nav>
    </div>
  </header>

  <main class="container main">
