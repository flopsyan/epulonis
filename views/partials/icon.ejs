<%
  // Monochrome line icons (stroke = currentColor). Kept as a small inline set so
  // the UI chrome stays emoji-free and the icons inherit theme colors.
  const icons = {
    // active / hands-on time (stopwatch)
    watch: '<circle cx="12" cy="13" r="8"/><path d="M12 9v4l2.5 1.5"/><path d="M9 1.5h6"/><path d="M12 1.5v3.5"/>',
    // cook / bake time (pot)
    pot: '<path d="M2 11h20"/><path d="M4 11v7a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7"/><path d="m4.5 7 15-3.5"/><path d="m8.6 6-.4-1.7a2 2 0 0 1 1.5-2.4l1.9-.4a2 2 0 0 1 2.4 1.5l.4 1.7"/>',
    // resting time (hourglass)
    hourglass: '<path d="M6 2h12"/><path d="M6 22h12"/><path d="M17 22v-3.2a2 2 0 0 0-.6-1.4L12 13l-4.4 4.4a2 2 0 0 0-.6 1.4V22"/><path d="M7 2v3.2a2 2 0 0 0 .6 1.4L12 11l4.4-4.4a2 2 0 0 0 .6-1.4V2"/>',
    // total time (clock)
    clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/>',
    // difficulty (ascending bars)
    gauge: '<path d="M6 20v-5"/><path d="M12 20V9"/><path d="M18 20V4"/>',
    // servings (fork & knife)
    servings: '<path d="M4 3v6a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2V3"/><path d="M7 3v18"/><path d="M19 14V3a4 4 0 0 0-3 3.9V11a2 2 0 0 0 2 2h1Zm0 0v7"/>',
  };
  const _name = typeof name !== 'undefined' ? name : '';
  const _cls = typeof cls !== 'undefined' && cls ? ' ' + cls : '';
%><svg class="icon<%= _cls %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><%- icons[_name] || '' %></svg>
