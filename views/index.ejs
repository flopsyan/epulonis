<%- include('partials/header') %>

<% if (isSearch) { %>
  <div class="page-head">
    <h1><%= t('search_results') %></h1>
    <p class="page-sub">
      <%= recipes.length %> <%= recipes.length === 1 ? t('match_one') : t('match_many') %>
      <%= t('for_query') %> „<strong><%= query %></strong>“ ·
      <a href="/"><%= t('back_overview') %></a>
    </p>
  </div>
<% } else { %>
  <%
    // Build an overview URL, preserving the other active filter dimension so the
    // tag and owner filters combine ("Desserts by Anna").
    function filterUrl(opts) {
      const p = new URLSearchParams();
      if (opts.tag) p.set('tag', opts.tag);
      if (opts.author) p.set('author', opts.author);
      const qs = p.toString();
      return qs ? `/?${qs}` : '/';
    }
    const curTag = activeTag ? activeTag.slug : null;
    const curAuthor = activeAuthor ? activeAuthor.id : null;
  %>
  <div class="page-head">
    <h1><% if (activeTag) { %><%= activeTag.name %><% } else if (activeAuthor) { %><%= t('recipes_by') %> <%= activeAuthor.display_name || activeAuthor.username %><% } else { %><%= t('all_recipes') %><% } %></h1>
    <p class="page-sub">
      <% if (activeTag || activeAuthor) { %>
        <%= recipes.length %> <%= recipes.length === 1 ? t('recipe_one') : t('recipe_many') %> ·
        <a href="<%= filterUrl({}) %>"><%= t('show_all') %></a>
      <% } else { %>
        <%= recipes.length %> <%= recipes.length === 1 ? t('recipe_one') : t('recipe_many') %> <%= t('in_collection') %>
      <% } %>
    </p>
  </div>

  <% if (tags && tags.length) { %>
    <nav class="filter-bar" aria-label="<%= t('filter_aria') %>">
      <a class="chip <%= !activeTag ? 'active' : '' %>" href="<%= filterUrl({ author: curAuthor }) %>"><%= t('chip_all') %></a>
      <% tags.forEach((tag) => { %>
        <a class="chip <%= curTag === tag.slug ? 'active' : '' %>" href="<%= filterUrl({ tag: tag.slug, author: curAuthor }) %>">
          <%= tag.name %> <span class="chip-count"><%= tag.count %></span>
        </a>
      <% }) %>
    </nav>
  <% } %>

  <% if (authors && authors.length) { %>
    <nav class="filter-bar owner-filter" aria-label="<%= t('filter_owner_aria') %>">
      <span class="filter-label"><%= t('owner_filter') %></span>
      <a class="chip <%= !activeAuthor ? 'active' : '' %>" href="<%= filterUrl({ tag: curTag }) %>"><%= t('chip_all') %></a>
      <% authors.forEach((a) => { %>
        <a class="chip <%= curAuthor === a.id ? 'active' : '' %>" href="<%= filterUrl({ tag: curTag, author: a.id }) %>">
          <%= a.display_name || a.username %> <span class="chip-count"><%= a.count %></span>
        </a>
      <% }) %>
    </nav>
  <% } %>
<% } %>

<% if (recipes.length === 0) { %>
  <div class="empty-state">
    <div class="empty-emoji">🍳</div>
    <% if (isSearch) { %>
      <h2><%= t('empty_no_matches') %></h2>
      <p><%= t('nothing_found_1') %> „<%= query %>“ <%= t('nothing_found_2') %></p>
      <a class="btn btn-primary" href="/"><%= t('browse_all') %></a>
    <% } else { %>
      <h2><%= t('empty_no_recipes') %></h2>
      <p><%= t('empty_no_recipes_text') %></p>
      <a class="btn btn-primary" href="/new"><%= t('create_first') %></a>
    <% } %>
  </div>
<% } else { %>
  <div class="recipe-grid">
    <% recipes.forEach((recipe) => { %>
      <%- include('partials/recipe-card', { recipe }) %>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
