# Epulonis configuration.
# Copy this file to ".env" and adjust the values.

# Host port the platform is reachable on (http://localhost:PORT)
PORT=3000

# Name shown in the header and the browser tab
SITE_NAME=Epulonis

# Seed example recipes + example pantry on the very first start?
# true  = create demo data (recommended for trying it out)
# false = start empty
SEED_DEMO=true

# Only relevant when running without Docker (npm start):
# storage location of the SQLite database
# DATA_DIR=./data

# --- Edit protection (login) -------------------------------------------------
# The site is public and read-only by default. AUTH_USER/AUTH_PASSWORD bootstrap
# the FIRST admin account (created on first start). After that, manage accounts
# in the UI under the avatar menu -> Settings; all accounts have equal rights.
# As long as AUTH_PASSWORD is empty AND no account exists, the site stays
# read-only (nobody can edit).
AUTH_PASSWORD=
# Username for the first admin account (defaults to "admin" if left empty).
AUTH_USER=admin
# Optional: secret for signing session cookies. If empty, a random one is
# generated and stored in the database (stable across restarts).
# AUTH_SECRET=
