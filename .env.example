# Konfiguration der Rezeptplattform.
# Kopiere diese Datei nach ".env" und passe die Werte an.

# Host-Port, unter dem die Plattform erreichbar ist (http://localhost:PORT)
PORT=3000

# Name, der im Kopfbereich und im Browser-Tab angezeigt wird
SITE_NAME=Epulonis

# Beim allerersten Start Beispielrezepte + Beispielvorrat einspielen?
# true  = Demodaten anlegen (empfohlen zum Ausprobieren)
# false = leer starten
SEED_DEMO=true

# Nur relevant beim Start ohne Docker (npm start):
# Speicherort der SQLite-Datenbank
# DATA_DIR=./data
